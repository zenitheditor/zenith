// @zenith/theme.cobalt — crisp corporate indigo/blue, large rounded boxes
// scheme: light | depth: 0 | noise: 1 (1 = apply a noise/grain filter)
zenith version=1 {
  project id="@zenith/theme.cobalt" name="Theme: cobalt"
  libraries {
    library id="@zenith/theme.cobalt" version="1.0.0"
  }
  tokens format="zenith-token-v1" {
    token id="color.base.100" type="color" set="@zenith/theme.cobalt" value="#f7f9fa"
    token id="color.base.200" type="color" set="@zenith/theme.cobalt" value="#eef2f6"
    token id="color.base.300" type="color" set="@zenith/theme.cobalt" value="#dfe5ed"
    token id="color.base.content" type="color" set="@zenith/theme.cobalt" value="#0d1529"
    token id="color.primary" type="color" set="@zenith/theme.cobalt" value="#605dff"
    token id="color.primary.content" type="color" set="@zenith/theme.cobalt" value="#edf1fe"
    token id="color.secondary" type="color" set="@zenith/theme.cobalt" value="#61738d"
    token id="color.secondary.content" type="color" set="@zenith/theme.cobalt" value="#f7f9fa"
    token id="color.accent" type="color" set="@zenith/theme.cobalt" value="#00a4f2"
    token id="color.accent.content" type="color" set="@zenith/theme.cobalt" value="#edf7fd"
    token id="color.neutral" type="color" set="@zenith/theme.cobalt" value="#1a273a"
    token id="color.neutral.content" type="color" set="@zenith/theme.cobalt" value="#f7f9fa"
    token id="color.info" type="color" set="@zenith/theme.cobalt" value="#0082ce"
    token id="color.info.content" type="color" set="@zenith/theme.cobalt" value="#edf7fd"
    token id="color.success" type="color" set="@zenith/theme.cobalt" value="#009689"
    token id="color.success.content" type="color" set="@zenith/theme.cobalt" value="#effcf9"
    token id="color.warning" type="color" set="@zenith/theme.cobalt" value="#d08700"
    token id="color.warning.content" type="color" set="@zenith/theme.cobalt" value="#fcfae6"
    token id="color.error" type="color" set="@zenith/theme.cobalt" value="#ea003e"
    token id="color.error.content" type="color" set="@zenith/theme.cobalt" value="#fceeef"
    token id="radius.box" type="dimension" set="@zenith/theme.cobalt" value=(px)32
    token id="radius.field" type="dimension" set="@zenith/theme.cobalt" value=(px)4
    token id="radius.selector" type="dimension" set="@zenith/theme.cobalt" value=(px)8
    token id="border.width" type="dimension" set="@zenith/theme.cobalt" value=(px)1
    token id="space.unit" type="dimension" set="@zenith/theme.cobalt" value=(px)4
    token id="font.heading" type="fontFamily" set="@zenith/theme.cobalt" value="Noto Sans"
    token id="font.body" type="fontFamily" set="@zenith/theme.cobalt" value="Noto Sans"
    token id="size.h1" type="dimension" set="@zenith/theme.cobalt" value=(px)64
    token id="size.h2" type="dimension" set="@zenith/theme.cobalt" value=(px)40
    token id="size.body" type="dimension" set="@zenith/theme.cobalt" value=(px)28
    token id="size.caption" type="dimension" set="@zenith/theme.cobalt" value=(px)18
  }
  styles {}
  document id="theme.cobalt.preview" title="Theme cobalt" {
    page id="pg" w=(px)760 h=(px)220 background=(token)"color.base.100" {
      text id="t.title" x=(px)40 y=(px)28 w=(px)680 h=(px)52 fill=(token)"color.base.content" font-family=(token)"font.heading" font-size=(token)"size.h2" { span "cobalt" }
      rect id="sw.primary" x=(px)40 y=(px)104 w=(px)160 h=(px)84 fill=(token)"color.primary" radius=(token)"radius.box"
      rect id="sw.secondary" x=(px)220 y=(px)104 w=(px)160 h=(px)84 fill=(token)"color.secondary" radius=(token)"radius.box"
      rect id="sw.accent" x=(px)400 y=(px)104 w=(px)160 h=(px)84 fill=(token)"color.accent" radius=(token)"radius.box"
      rect id="sw.neutral" x=(px)580 y=(px)104 w=(px)160 h=(px)84 fill=(token)"color.neutral" radius=(token)"radius.box"
    }
  }
}
